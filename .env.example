# Copy to .env on the server and chmod 600 .env.
# Never commit the real .env file.

# Public endpoint / TLS.
OPENWEBUI_HOST=gpt.alpha-soft.ru
LETSENCRYPT_EMAIL=kwentin3@mail.ru

# Image tags.
# OpenWebUI docs recommend pinned version tags for production-like stability.
OPENWEBUI_BASE_IMAGE=ghcr.io/open-webui/open-webui:v0.9.6
OPENWEBUI_IMAGE=corp-openwebui/openwebui:v0.9.6-native-web-stt-broker-intake-v2
BROKER_REPORTS_SOURCE_REVISION=replace-with-exact-git-revision
TRAEFIK_IMAGE=traefik:v3.6

# Low-cost built-in customization. This is not white-labeling.
WEBUI_NAME="Alpha Soft AI Chat"
WEBUI_BANNERS="[{\"id\":\"prd0-policy-warning-v1\",\"type\":\"warning\",\"title\":\"Тестовый корпоративный AI-чат\",\"content\":\"Не отправляйте пароли, токены, API-ключи, приватные SSH-ключи и закрытые персональные данные. Ответы модели нужно проверять.\",\"dismissible\":true,\"timestamp\":1780963200}]"

# Primary provider through .env: OpenAI.
# Put the real API key only in .env or a password manager.
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-openai-api-key
DEFAULT_MODELS=gpt-5.4-mini

# Secondary provider through OpenWebUI Admin UI: Gemini.
# Do not put the Gemini API key in this file for PRD-0.
# Admin UI base URL: https://generativelanguage.googleapis.com/v1beta/openai
# Admin UI model id: gemini-3.5-flash
# If testing Gemini 3 Flash Preview specifically: gemini-3-flash-preview

# Optional outbound proxy for provider egress.
# OpenWebUI and stage2-stt provider HTTP clients expect an HTTP proxy here.
# For SOCKS5, run a local HTTP-to-SOCKS bridge and keep SOCKS5 upstream separate.
# Keep real proxy credentials only in .env / password manager.
OPENWEBUI_OUTBOUND_PROXY=
OPENWEBUI_SOCKS5_UPSTREAM=
OPENWEBUI_NO_PROXY=localhost,127.0.0.1,::1,openwebui,traefik,openwebui-traefik,stage2-stt,stage2-stt:8080,searxng,searxng:8080,searxng-valkey,gpt.alpha-soft.ru

# Stage 2 / Web Search / private SearXNG candidate.
# Use only with compose/searxng.private.compose.yml. Keep real secrets in
# server-local .env; never commit generated secret values.
SEARXNG_IMAGE=docker.io/searxng/searxng:latest
SEARXNG_VALKEY_IMAGE=docker.io/valkey/valkey:8-alpine
SEARXNG_SECRET=replace-with-random-strong-searxng-secret
SEARXNG_BASE_URL=
SEARXNG_LIMITER=true
SEARXNG_PUBLIC_INSTANCE=false
SEARXNG_IMAGE_PROXY=false
SEARXNG_VALKEY_URL=valkey://searxng-valkey:6379/0
ENABLE_WEB_SEARCH=true
WEB_SEARCH_ENGINE=searxng
WEB_SEARCH_RESULT_COUNT=3
WEB_SEARCH_CONCURRENT_REQUESTS=1
WEB_LOADER_CONCURRENT_REQUESTS=2
WEB_SEARCH_TRUST_ENV=true
BYPASS_WEB_SEARCH_WEB_LOADER=false
SEARXNG_QUERY_URL=http://searxng:8080/search?q=<query>
SEARXNG_LANGUAGE=ru
SEARXNG_DEBUG_BIND=127.0.0.1
SEARXNG_DEBUG_PORT=18080

# Stage 2 / Web Search / Brave Search API.
# Current working baseline uses brave_llm_context. Keep the real API key in
# server-local .env or OpenWebUI Admin UI; never commit key values.
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_CONTEXT_TOKENS=8192

# Stage 2 / Web Search / Yandex Search API candidate.
# Use only after privacy/data-egress review. Keep the real API key in
# server-local .env or OpenWebUI Admin UI; never commit key values.
YANDEX_WEB_SEARCH_API_KEY=
YANDEX_WEB_SEARCH_URL=https://searchapi.api.cloud.yandex.net/v2/web/search
YANDEX_WEB_SEARCH_CONFIG=

# Stage 2 / STT proxy planning contract.
# These values are inert for PRD-0 unless Stage 2 code explicitly reads them.
# Keep real provider keys only in .env / password manager. Do not expose via NEXT_PUBLIC_*.
STAGE2_STT_PROVIDER=lemonfox
STAGE2_STT_PROVIDER_ADAPTER=lemonfox

# Lemonfox STT provider.
STAGE2_LEMONFOX_API_KEY=
STAGE2_LEMONFOX_BASE_URL=https://api.lemonfox.ai
STAGE2_LEMONFOX_MODEL=
STAGE2_LEMONFOX_LANGUAGE=ru
STAGE2_LEMONFOX_ENABLE_SPEAKER_LABELS=true
STAGE2_LEMONFOX_ENABLE_TIMESTAMPS=true
STAGE2_LEMONFOX_MAX_DIRECT_UPLOAD_MB=100
STAGE2_LEMONFOX_MAX_URL_UPLOAD_MB=1024
STAGE2_LEMONFOX_PROVIDER_MAX_DURATION_MINUTES=

# STT output profiles.
# Allowed: opus_webm_compact, opus_ogg_compact, mp3_high_compat, wav_pcm_safe.
STAGE2_STT_OUTPUT_PROFILE=mp3_high_compat
STAGE2_STT_FALLBACK_OUTPUT_PROFILE=mp3_high_compat

# STT browser input affordances.
STAGE2_STT_INPUT_ACCEPT_MODE=broad_ffmpeg_probe
STAGE2_STT_DECLARED_INPUT_EXTENSIONS=mp3,wav,m4a,webm,ogg,mp4,mov,mkv,avi,flac,aac
STAGE2_STT_DECLARED_INPUT_MIME_PREFIXES=audio/,video/
STAGE2_STT_REQUIRE_AUDIO_STREAM=true
STAGE2_STT_FFMPEG_PROBE_BEFORE_ACTION=true

# Browser ffmpeg preprocessing and assets.
STAGE2_FFMPEG_BROWSER_MAX_INPUT_MB=1024
STAGE2_FFMPEG_BROWSER_MAX_DURATION_MINUTES=
STAGE2_FFMPEG_ASSET_MODE=self_hosted
STAGE2_FFMPEG_CORE_BASE_URL=/static/stage2-assets/ffmpeg/0.12.6/
STAGE2_FFMPEG_PACKAGE_VERSION=0.12.6
STAGE2_FFMPEG_CORE_VERSION=0.12.6
STAGE2_FFMPEG_UTIL_VERSION=0.12.1

# STT prepared-audio storage and retention.
# STAGE2_STT_STORAGE_MODE: auto stores to S3/object storage only when configured
# and healthy; s3 requires healthy storage; none does not persist prepared audio.
STAGE2_STT_STORAGE_MODE=auto
STAGE2_STT_REQUIRE_STORAGE_HEALTH=false
STAGE2_STT_AUDIO_BUCKET=
STAGE2_STT_AUDIO_PREFIX=stage2/stt/prepared-audio/
STAGE2_STT_STORE_PREPARED_AUDIO=true
STAGE2_STT_STORE_SOURCE_MEDIA=false
STAGE2_STT_PREPARED_AUDIO_RETENTION_DAYS=
STAGE2_STT_TRANSCRIPT_RETENTION_DAYS=

# STT v2 internal artifact store.
# ArtifactStore is internal technical storage; refs are not user-visible history.
STAGE2_STT_ARTIFACT_STORE_MODE=sqlite
STAGE2_STT_ARTIFACT_STORE_PATH=/data/stage2-stt/artifacts.sqlite3
STAGE2_STT_ARTIFACT_PAYLOAD_DIR=/data/stage2-stt/artifact-payloads
STAGE2_STT_TRANSCRIPT_TTL_DAYS=14
STAGE2_STT_TRANSFORMATION_TTL_DAYS=14
STAGE2_STT_PREPARED_AUDIO_TTL_HOURS=24
STAGE2_STT_DIAGNOSTIC_PROVIDER_PAYLOAD_ENABLED=false
STAGE2_STT_DIAGNOSTIC_PROVIDER_PAYLOAD_TTL_HOURS=0
STAGE2_STT_ARTIFACT_ROTATION_INTERVAL_HOURS=24
STAGE2_STT_ARTIFACT_HARD_DELETE_AFTER_EXPIRY=true

# STT v2 post-processing prompt catalog.
# OpenWebUI Prompt body remains source of truth; sidecar reads metadata/body
# from the native prompt catalog and exposes only safe template metadata.
STAGE2_STT_PROMPT_CATALOG_MODE=openwebui_sqlite
STAGE2_STT_OPENWEBUI_PROMPT_DB_PATH=/openwebui-data/webui.db

# STT v2 post-processing executor.
# Base URL falls back to the existing server-local OPENAI_API_BASE_URL. The
# compose file maps STAGE2_STT_POSTPROCESSING_OPENAI_API_KEY from OPENAI_API_KEY;
# do not duplicate the secret here.
STAGE2_STT_POSTPROCESSING_EXECUTOR_MODE=disabled
STAGE2_STT_POSTPROCESSING_OPENAI_BASE_URL=
STAGE2_STT_POSTPROCESSING_OPENAI_MODEL=gpt-5.4-mini
STAGE2_STT_POSTPROCESSING_MAX_TRANSCRIPT_CHARS=60000

# Message-level DOCX export MVP limits.
STAGE2_STT_MESSAGE_DOCX_MAX_MESSAGE_CHARS=100000
STAGE2_STT_MESSAGE_DOCX_MAX_DOCX_MB=5

# STT provider limits and warnings.
STAGE2_STT_MAX_PREPARED_AUDIO_MB=100
STAGE2_STT_DIRECT_UPLOAD_WARNING_MB=100
STAGE2_STT_ON_PREPARED_AUDIO_TOO_LARGE=fail
STAGE2_STT_PROVIDER_MAX_DURATION_MINUTES=
STAGE2_STT_INTERNAL_MAX_DURATION_MINUTES=

# STT cancel behavior.
# Provider cancel is unknown for Lemonfox until runtime/provider proof.
STAGE2_STT_CANCEL_PROVIDER_IF_SUPPORTED=true
STAGE2_STT_CANCEL_LOCAL_ON_PROVIDER_NO_CANCEL=true
STAGE2_STT_PROVIDER_CANCEL_SUPPORT=unknown

# Runtime capabilities endpoint candidate:
# GET /stage2-api/transcription/capabilities

# Internal OpenWebUI Action -> sidecar auth.
# Generate a real value only in ignored/server-local .env. Do not expose to browser.
STAGE2_STT_INTERNAL_API_KEY=
STAGE2_STT_ALLOW_STUB_TRANSCRIPT=false

# Server secrets.
# Generate with: openssl rand -hex 32
# Keep stable across restarts and container recreates.
WEBUI_SECRET_KEY=replace-with-random-strong-secret
CORS_ALLOW_ORIGIN=https://gpt.alpha-soft.ru

# Admin bootstrap. Keep the real password only in .env / password manager.
WEBUI_ADMIN_EMAIL=admin@example.com
WEBUI_ADMIN_PASSWORD=replace-with-strong-password

# PRD-0 access defaults.
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=pending
WEBUI_AUTH=true

# Backup.
# Pilot retention choices: 1, 7 or 30 days. Default: 7 days.
BACKUP_DIR=/opt/backups/openwebui-prd0
BACKUP_RETENTION_DAYS=7
