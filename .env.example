# Copy to .env on the server and chmod 600 .env.
# Never commit the real .env file.

OPENWEBUI_HOST=gpt.alpha-soft.ru
LETSENCRYPT_EMAIL=admin@example.com

# OpenWebUI docs recommend pinned version tags for production-like stability.
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:v0.9.6
TRAEFIK_IMAGE=traefik:v3.6

# OpenAI-compatible provider.
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-provider-api-key

# Optional. Fill only after the exact model id is chosen.
DEFAULT_MODELS=

# Generate with: openssl rand -hex 32
# Keep stable across restarts and container recreates.
WEBUI_SECRET_KEY=replace-with-random-strong-secret
CORS_ALLOW_ORIGIN=https://gpt.alpha-soft.ru

# Admin bootstrap. Keep the real password only in .env / password manager.
WEBUI_ADMIN_EMAIL=admin@example.com
WEBUI_ADMIN_PASSWORD=replace-with-strong-password

# PRD-0 access defaults.
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=pending
WEBUI_AUTH=true
